extends layout

block content

  h1.mb-4 Mis favoritos

  if favorites.length === 0

    .alert.alert-secondary

      | No tenés publicaciones guardadas

  each post in favorites

    .card.mb-4.shadow-sm

      .card-body

        .d-flex.justify-content-between.align-items-start

          h2.card-title= post.title

          form(
            action=`/favorites/remove/${post.id}`
            method="POST"
          )

            button.btn.btn-sm.btn-outline-danger(
              type="submit"
              title="Quitar de favoritos"
            )

              i.bi.bi-x-lg

        p.card-text= post.description

        img.feed-image.rounded.mt-3(
          src=post.image
        )