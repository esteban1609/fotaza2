doctype html
html
  head
    title Registro
  body
    h1 Registro de usuario

    form(action="/register" method="POST")
      div
        label Username
        input(type="text" name="username")

      div
        label Email
        input(type="email" name="email")

      div
        label Password
        input(type="password" name="password")

      button(type="submit") Registrarse