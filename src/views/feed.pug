extends layout


block content

  h1.mb-4 Feed de publicaciones

  each post in posts

    .card.feed-card.mb-4.shadow-sm

      .card-body

        h2.card-title= post.title

        p.card-text= post.description

        p.text-muted
          | Autor: 
          a(
             href=`/users/${post.User.id}`
          )
            = post.User.username
          

        if post.User.id !== currentUser.id

          form(
            action=`/follow/${post.User.id}`
            method="POST"
            class="mb-3"
          )

            button.btn.btn-primary(type="submit")
              | Seguir

        - let average = 0

        if post.Ratings.length > 0

          - let total = 0

          each rating in post.Ratings
            - total += rating.value

          - average = (total / post.Ratings.length).toFixed(1)

        p.fw-bold
          | Valoración promedio: #{average} ⭐

        img.feed-image.rounded.mt-3.mb-3(
          src=post.image
        )

        h3 Comentarios

        each comment in post.Comments

          p
            strong #{comment.User.username}:
            |  #{comment.content}

        form(
          action=`/comments/create/${post.id}`
          method="POST"
          class="mt-3"
        )

          textarea.form-control.mb-2(
            name="content"
            placeholder="Escribí un comentario"
            rows="3"
          )

          button.btn.btn-success(type="submit")
            | Comentar

        br

        form(
          action=`/ratings/create/${post.id}`
          method="POST"
          class="mt-2"
        )

          select.form-select.mb-2(name="value")

            option(value="1") 1 estrella
            option(value="2") 2 estrellas
            option(value="3") 3 estrellas
            option(value="4") 4 estrellas
            option(value="5") 5 estrellas

          button.btn.btn-warning(type="submit")
            | Valorar