extends layout


block content

  h1.mb-4 Feed de publicaciones
  
  if posts.length === 0

    .alert.alert-warning.text-center

      h4.mb-2
        | No se encontraron publicaciones

      p.mb-0
        | Probá con otra búsqueda

  each post in posts

    .card.feed-card.mb-4.shadow-sm

      .card-body

        

        .d-flex.justify-content-between.align-items-center.mb-3
        

          .d-flex.align-items-center

            if post.User && post.User.profile_image

              img.rounded-circle.me-3(
                src=post.User.profile_image
                width="50"
                height="50"
              )

            else

              i.bi.bi-person-circle.fs-1.me-3

            div

              if post.User

                a.fw-bold.text-decoration-none(
                  href=`/users/${post.User.id}`
                )

                  = post.User.username

              else

                span Usuario desconocido

              br

              small.text-muted

                = post.createdAt.toLocaleDateString()
            
          .dropdown

            button.btn.btn-sm.btn-light(
              type="button"
              data-bs-toggle="dropdown"
            )

              i.bi.bi-three-dots-vertical

            ul.dropdown-menu.dropdown-menu-end

              if currentUser.id === post.UserId

                li

                  a.dropdown-item(
                    href=`/posts/${post.id}/interests`
                  )

                    | Ver interesados

                li

                  form(
                    action=`/posts/toggle-comments/${post.id}`
                    method="POST"
                  )

                    button.dropdown-item(
                      type="submit"
                    )

                      if post.commentsEnabled

                        | Cerrar comentarios

                      else

                        | Abrir comentarios

              else

                li

                  a.dropdown-item.text-danger(
                    href=`/reports/create/${post.id}`
                  )

                    | Denunciar

        h2.card-title.mb-2

          = post.title

        p.card-text

          = post.description

        if post.tags

          p.mb-3

            each tag in post.tags.split(",")

              span.badge.bg-primary.me-1

                | ##{tag.trim()}

        if post.copyright

          p.text-danger.mb-2

            | © Copyright protegido

        else

          p.text-success.mb-2

            | Libre de copyright

        - let average = 0

        if post.Ratings.length > 0

          - let total = 0

          each rating in post.Ratings
            - total += rating.value

          - average = (total / post.Ratings.length).toFixed(1)

        - const roundedAverage = Math.round(average)

         p.fw-bold.mb-2

          | Valoración: 

          each star in [1,2,3,4,5]

            if star <= roundedAverage

              span.text-warning ⭐

            else

              span.text-secondary ☆

          |  (#{average})

        .d-flex.gap-4.mb-3.mt-3

          span

            | 💬 #{post.Comments.length}

          span

            | ❤️ #{post.Interests.length}

        - const isFavorite = favorites.some(favorite => favorite.PostId === post.id)

        form(
          action=`/favorites/${post.id}`
          method="POST"
        )

          select.form-select.mb-2(
            name="CollectionId"
          )

            each collection in collections

              option(
                value=collection.id
              )

                = collection.name

          button.btn.btn-outline-dark(
            type="submit"
          )

            | Guardar  
        
        form(
          action=`/interest/${post.id}`
          method="POST"
          class="mt-2"
        )

          button.btn.btn-info(
            type="submit"
          )

            |  Me interesa
        

        .image-container.mt-3.mb-3

          .image-background(
            style=`background-image: url('${post.image}')`
          )

          img.feed-image.rounded(
            src=post.image
          )

        h3 Comentarios

        each comment in post.Comments

          .d-flex.align-items-center.mb-2

            if comment.User.profile_image

              img.rounded-circle.me-2(
                src=comment.User.profile_image
                width="30"
                height="30"
              )

            strong #{comment.User.username}:

            span.ms-2
              = comment.content

        if post.commentsEnabled
          
          form(
            action=`/comments/create/${post.id}`
            method="POST"
            class="mt-3"
          )

            textarea.form-control.mb-2(
              name="content"
              placeholder="Escribí un comentario"
              rows="3"
            )

            button.btn.btn-success(type="submit")
              | Comentar

        else

          p.text-danger

            | Comentarios cerrados por el autor
        
        br

        form(
          action=`/ratings/create/${post.id}`
          method="POST"
          class="mt-2"
        )

          select.form-select.mb-2(name="value")

            option(value="1") 1 estrella
            option(value="2") 2 estrellas
            option(value="3") 3 estrellas
            option(value="4") 4 estrellas
            option(value="5") 5 estrellas

          button.btn.btn-warning(type="submit")
            | Valorar