extends layout

block content

  .row.justify-content-center

    .col-lg-8

      .card.shadow-sm.border-0.mb-4

        .card-body.text-center

          if profileUser.profile_image

            img.rounded-circle.mb-3(
              src=profileUser.profile_image
              width="150"
              height="150"
            )

          else

            i.bi.bi-person-circle.display-1

          h1.mb-3
            = profileUser.username

          p.text-muted
            = profileUser.email
          
          small.text-muted

            | Miembro desde #{new Date(profileUser.createdAt).toLocaleDateString()}

          .row.text-center.mt-4

            .col

              h4= postCount

              p.text-muted Publicaciones

            .col

              h4= followers.length

              p.text-muted Seguidores

            .col

              h4= following.length

              p.text-muted Siguiendo

            .col

              h4= favoriteCount

              p.text-muted Favoritos

          if loggedUser && loggedUser.id === profileUser.id

            a.btn.btn-outline-primary.mt-3(
              href="/profile/edit"
            )

              | Editar perfil

      h2.mb-4
        | Publicaciones

      if posts.length === 0

        .alert.alert-secondary

          | Este usuario todavía no publicó nada

      else

        .row

          each post in posts

            .col-md-4.mb-4

              .card.shadow-sm.h-100

                img.card-img-top(
                  src=post.image
                )

                .card-body

                  h6.card-title
                    = post.title