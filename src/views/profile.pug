extends layout

block content

  .row.justify-content-center

    .col-lg-8

      .card.shadow-sm.border-0.mb-4

        .card-body.text-center

          h1.mb-3
            = profileUser.username

          p.text-muted
            = profileUser.email

          .d-flex.justify-content-center.gap-4.mt-4

            .text-center

              h4
                = followers.length

              p.text-muted
                | Seguidores

            .text-center

              h4
                = following.length

              p.text-muted
                | Siguiendo

            .text-center

              h4
                = posts.length

              p.text-muted
                | Posts

      h2.mb-4
        | Publicaciones

      if posts.length === 0

        .alert.alert-secondary

          | Este usuario todavía no publicó nada

      each post in posts

        .card.mb-4.shadow-sm

          .card-body

            h3.card-title
              = post.title

            p.card-text
              = post.description

            img.feed-image.rounded.mt-2(
              src=post.image
            )