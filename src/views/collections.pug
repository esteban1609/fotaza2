extends layout

block content

  h1.mb-4 Mis colecciones

  form(
    action="/collections/create"
    method="POST"
    class="mb-4"
  )

    .input-group

      input.form-control(
        name="name"
        placeholder="Nombre de la colección"
      )

      button.btn.btn-primary(
        type="submit"
      )

        | Crear colección

  if collections.length === 0

    .alert.alert-secondary

      | Todavía no creaste ninguna colección

  else

    .row

      each collection in collections

        .col-md-6.col-lg-4.mb-4

          .card.shadow-sm.h-100

            .card-body.text-center

              i.bi.bi-folder-fill.display-3.text-warning

              h4.mt-3

                a.text-decoration-none(
                  href=`/collections/${collection.id}`
                )

                  = collection.name

              p.text-muted.mb-0

                | #{collection.Favorites.length} publicaciones
              
              form(
                action=`/collections/delete/${collection.id}`
                method="POST"
              )

                button.btn.btn-sm.btn-danger(
                  type="submit"
                )

                  | Eliminar